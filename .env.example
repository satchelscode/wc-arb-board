# Required
ODDS_API_KEY=
DATABASE_URL=sqlite:///./wc_arb.db

# macOS often uses port 5000 for AirPlay — use 5001 locally
PORT=5001

# Scan interval (worker)
SCAN_INTERVAL_SECONDS=300

# Odds API — retail / sharp books
ODDS_API_BOOKS=pinnacle,draftkings,fanduel,betonlineag,bookmaker
ODDS_API_REGIONS=us,eu
ODDS_API_MARKETS=h2h,spreads,totals,team_totals
ODDS_API_PROP_MARKETS=player_goal_scorer_anytime,player_first_goal_scorer,alternate_spreads,alternate_totals
ODDS_API_SPORT_KEY=soccer_fifa_world_cup
ODDS_API_MAX_EVENTS=80
MIN_EDGE_PCT=0.01
# Kalshi binary asks are not comparable to PPH O/U — keep excluded unless tuned.
ARB_EXCLUDE_BOOKS=kalshi
# Cross-book arbs only for these markets (props/futures need exact label match).
ARB_MARKETS=team_totals,totals

# ACE (backend host is falcon.ag — shown as ACE on the site)
FALCON_ENABLED=true
FALCON_LOGIN_URL=https://backend.falcon.ag/
FALCON_STRAIGHT_URL=https://backend.falcon.ag/wager/CreateSports.aspx?WT=0
# All Falcon WC leagues in one helper request (main lines, team totals, props, etc.)
FALCON_WC_LG_IDS=3744,3745,3749,3752,4120,4069,866,3829,3830,3831,3832,3833,3834,3835,5091,5092,5093,5094
FALCON_WC_HELPER_URL=https://backend.falcon.ag/wager/NewScheduleHelper.aspx?WT=0&lg=3744,3745,3749,3752,4120,4069,866,3829,3830,3831,3832,3833,3834,3835,5091,5092,5093,5094
# Optional extra helper URLs (comma-separated full URLs)
# FALCON_WC_HELPER_URLS=
FALCON_USERNAME=
FALCON_PASSWORD=
# FALCON_COOKIE=

# Metallic = Steam22 player site (steam22.com) — NOT an ACE backend
METALLIC_ENABLED=false
METALLIC_USERNAME=
METALLIC_PASSWORD=
METALLIC_SCHEDULE_URL=https://steam22.com/player-api/api/wager/schedules/S/0
# Leave blank — worker auto-discovers sport ids or falls back to IdSport 232 (FIFA WC).
# Override only if needed (paste Payload from DevTools schedules/S/0 request):
# METALLIC_SCHEDULE_POST_BODY=[{"IdSport":232,"Period":0},{"IdSport":232,"Period":1},{"IdSport":396,"Period":0},{"IdSport":231,"Period":0}]
METALLIC_LOGIN_WEBSITE=steam22.com
METALLIC_JS_VERSION=1.3.47
METALLIC_REFERER=https://steam22.com/v2/

# Buckeye2 = kraken69.com cloud API (not ACE backend)
BUCKEYE2_ENABLED=false
BUCKEYE2_USERNAME=
BUCKEYE2_PASSWORD=
BUCKEYE2_AUTH_USERID=
# Optional: paste JWT from DevTools if password login fails on Render
# BUCKEYE2_BEARER_TOKEN=
BUCKEYE2_LINES_URL=https://www.kraken69.com/cloud/api/Lines/Get_LeagueLines2
BUCKEYE2_LOGIN_URL=https://www.kraken69.com/cloud/api/System/authenticateCustomer
BUCKEYE2_RENEW_URL=https://www.kraken69.com/cloud/api/System/renewToken
BUCKEYE2_DOMAIN=kraken69.com
BUCKEYE2_LINES_POST_BODY={}
BUCKEYE2_API_ORIGIN=https://www.kraken69.com
BUCKEYE2_REFERER=https://www.kraken69.com/

# Kalshi — sharp exchange (public read API, no key required)
KALSHI_ENABLED=false
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_SERIES_TICKERS=KXWCGAME,KXWCTOTAL,KXWCTEAMTOTAL,KXWCSPREAD,KXWCGOAL
KALSHI_MARKET_STATUS=open

# BetVegas23 (ACE) — optional second skin
BETVEGAS23_ENABLED=false
BETVEGAS23_LOGIN_URL=https://backend.betvegas23.com/
BETVEGAS23_STRAIGHT_URL=https://backend.betvegas23.com/wager/CreateSports.aspx?WT=0
BETVEGAS23_WC_HELPER_URL=https://backend.betvegas23.com/wager/NewScheduleHelper.aspx?WT=0&lg=3749
BETVEGAS23_USERNAME=
BETVEGAS23_PASSWORD=
